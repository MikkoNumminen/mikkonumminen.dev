---
import '../../styles/mountain-scene.css';
---

<div class="mountain-scene" data-mountain-scene aria-hidden="true">
  <!-- Sky gradient — color tweens via GSAP, controlled by --sky-top / --sky-bottom -->
  <div class="layer layer--sky" data-layer="sky"></div>

  <!-- Stars — visible at dawn, fade out toward day -->
  <div class="layer layer--stars" data-layer="stars">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      focusable="false"
    >
      {
        Array.from({ length: 90 }).map((_, i) => {
          const x = (i * 137.5) % 1600;
          const y = (i * 47) % 600;
          const r = 0.6 + ((i * 13) % 20) / 20;
          const o = 0.4 + ((i * 7) % 60) / 100;
          return <circle cx={x} cy={y} r={r} fill="white" opacity={o} />;
        })
      }
    </svg>
  </div>

  <!-- Sun — rises with scroll progress, controlled by --sun-y -->
  <div class="layer layer--sun" data-layer="sun">
    <div class="sun">
      <div class="sun__core"></div>
      <div class="sun__halo"></div>
    </div>
  </div>

  <!-- Far mountains -->
  <div class="layer layer--far" data-layer="far" data-parallax-speed="0.10">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="far-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--far-top, #5b4d6b)"></stop>
          <stop offset="100%" stop-color="var(--far-bottom, #3a2f48)"></stop>
        </linearGradient>
      </defs>
      <polygon
        fill="url(#far-grad)"
        points="
          0,900
          0,560
          120,500 220,540 320,470 410,510 520,440 620,490 730,420
          850,470 960,400 1070,460 1170,410 1280,470 1380,420 1490,470 1600,440
          1600,900
        "
      ></polygon>
    </svg>
  </div>

  <!-- Mid mountains -->
  <div class="layer layer--mid" data-layer="mid" data-parallax-speed="0.18">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="mid-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--mid-top, #4a3a5a)"></stop>
          <stop offset="100%" stop-color="var(--mid-bottom, #2a2236)"></stop>
        </linearGradient>
      </defs>
      <polygon
        fill="url(#mid-grad)"
        points="
          0,900
          0,650
          80,610 200,560 300,620 420,540 540,590 660,520 780,580
          900,510 1020,580 1140,540 1260,610 1380,570 1500,620 1600,580
          1600,900
        "
      ></polygon>
    </svg>
  </div>

  <!-- Near mountains (the climbing slope) -->
  <div class="layer layer--near" data-layer="near" data-parallax-speed="0.30">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="near-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--near-top, #2e2438)"></stop>
          <stop offset="100%" stop-color="var(--near-bottom, #16121e)"></stop>
        </linearGradient>
      </defs>
      <polygon
        fill="url(#near-grad)"
        points="
          0,900
          0,800
          200,720 360,780 520,640 680,720 820,580 960,680
          1100,560 1260,640 1400,560 1520,650 1600,600
          1600,900
        "
      ></polygon>
    </svg>
  </div>

  <!-- Trees / forest line -->
  <div class="layer layer--trees" data-layer="trees" data-parallax-speed="0.45">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      focusable="false"
    >
      <g fill="var(--trees-color, #1a1424)">
        {
          Array.from({ length: 60 }).map((_, i) => {
            const x = (i * 27) % 1600;
            const h = 30 + ((i * 9) % 30);
            const y = 820 - ((i * 11) % 25);
            return <polygon points={`${x - 8},${y} ${x},${y - h} ${x + 8},${y}`} />;
          })
        }
      </g>
    </svg>
  </div>

  <!-- Foreground hill (closest, fastest parallax) -->
  <div class="layer layer--foreground" data-layer="foreground" data-parallax-speed="0.65">
    <svg
      viewBox="0 0 1600 900"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient id="fg-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--fg-top, #100a18)"></stop>
          <stop offset="100%" stop-color="var(--fg-bottom, #050308)"></stop>
        </linearGradient>
      </defs>
      <polygon
        fill="url(#fg-grad)"
        points="
          0,900 0,820
          240,760 460,820 700,720 940,800 1180,740 1420,810 1600,760
          1600,900
        "
      ></polygon>
    </svg>
  </div>
</div>

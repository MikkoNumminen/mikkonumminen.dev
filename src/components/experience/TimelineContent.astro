---
import '../../styles/experience-timeline.css';
import { localizeTimeline } from '../../data/timeline';
import { asLocale, getTranslations, localizePath } from '../../i18n';
import LinkifiedText from './LinkifiedText.astro';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
const timeline = localizeTimeline(t);

const kindLabel: Record<string, string> = {
  foundation: t.experiencePage.kindFoundation,
  work: t.experiencePage.kindWork,
  life: t.experiencePage.kindLife,
  project: t.experiencePage.kindProject,
  craft: t.experiencePage.kindCraft,
  now: t.experiencePage.kindNow,
};

// The display-type "ghost" year that sits behind each card uses just the
// last 4 chars of the year string (so "1998–2022" becomes "2022", "Now"
// stays "Now") — keeps the ghost column visually consistent across
// foundation entries that span multiple years and recent year-only entries.
function ghostYear(year: string): string {
  const trimmed = year.trim();
  // Year ranges separated by an en-dash use the upper bound for the ghost
  // (the year the chapter ends).
  const dash = trimmed.lastIndexOf('–');
  if (dash >= 0) return trimmed.slice(dash + 1).trim();
  return trimmed;
}
---

<div class="timeline" data-timeline>
  <header class="timeline__header">
    <p class="timeline__eyebrow">
      <span class="timeline__eyebrow-bar" aria-hidden="true"></span>
      <span class="timeline__eyebrow-text">{t.experiencePage.eyebrow}</span>
    </p>
    <h1 class="timeline__title">{t.experiencePage.title}</h1>
    <p class="timeline__lede">{t.experiencePage.lede}</p>
    <p class="timeline__hint" aria-hidden="true">
      <span>{t.experiencePage.scrollHint}</span>
      <svg
        width="14"
        height="22"
        viewBox="0 0 14 22"
        fill="none"
        aria-hidden="true"
        focusable="false"
      >
        <rect x="0.5" y="0.5" width="13" height="21" rx="6.5" stroke="currentColor"
        ></rect>
        <circle cx="7" cy="7" r="1.5" fill="currentColor" class="timeline__scroll-circle"></circle>
      </svg>
    </p>
  </header>

  <ol class="timeline__list">
    {
      timeline.map((entry) => (
        <li
          class="timeline__entry"
          data-timeline-entry
          data-altitude={entry.altitude}
          data-kind={entry.kind}
        >
          <div class="timeline__marker" aria-hidden="true">
            <span class="timeline__dot">
              <span class="timeline__dot-ring" />
              <span class="timeline__dot-ring timeline__dot-ring--late" />
            </span>
            <span class="timeline__line" />
          </div>
          <div class="timeline__card">
            <span class="timeline__year-bg" aria-hidden="true">
              {ghostYear(entry.year)}
            </span>
            <div class="timeline__meta">
              <span class="timeline__year">{entry.year}</span>
              <span class="timeline__kind">{kindLabel[entry.kind]}</span>
            </div>
            <h2 class="timeline__heading">{entry.title}</h2>
            <div class="timeline__body">
              {entry.body.split(/\n\n+/).map((paragraph) => (
                <p>
                  <LinkifiedText text={paragraph} />
                </p>
              ))}
            </div>
            {entry.lessons && entry.lessons.length > 0 && (
              <ol class="timeline__lessons" aria-label={t.experiencePage.lessonsAriaLabel}>
                {entry.lessons.map((lesson) => (
                  <li class="timeline__lesson">
                    <span class="timeline__lesson-marker" aria-hidden="true" />
                    <div class="timeline__lesson-content">
                      <h3 class="timeline__lesson-title">{lesson.title}</h3>
                      <p class="timeline__lesson-body">
                        <LinkifiedText text={lesson.body} />
                      </p>
                    </div>
                  </li>
                ))}
              </ol>
            )}
            {entry.tags && (
              <ul class="timeline__tags">
                {entry.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))
    }
  </ol>

  <footer class="timeline__summit">
    <p>{t.experiencePage.summit}</p>
    <a href={localizePath('/contact', locale)} class="timeline__cta">
      <span class="timeline__cta-glow" aria-hidden="true"></span>
      <span class="timeline__cta-text">{t.experiencePage.cta}</span>
    </a>
  </footer>
</div>

<style>
  @keyframes timeline-scroll-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  .timeline__scroll-circle {
    animation: timeline-scroll-bob 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline__scroll-circle {
      animation: none;
    }
  }
</style>

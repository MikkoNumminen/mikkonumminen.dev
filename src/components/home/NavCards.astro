---
import { asLocale, getTranslations, localizePath } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);

const cards = [
  {
    href: localizePath('/projects', locale),
    label: t.navCards.projects.label,
    description: t.navCards.projects.description,
    accent: 'projects',
    icon: 'planet',
  },
  {
    href: localizePath('/experience', locale),
    label: t.navCards.experience.label,
    description: t.navCards.experience.description,
    accent: 'experience',
    icon: 'mountain',
  },
  {
    href: localizePath('/contact', locale),
    label: t.navCards.contact.label,
    description: t.navCards.contact.description,
    accent: 'contact',
    icon: 'terminal',
  },
];
---

<section class="nav-cards" data-section-nav-cards aria-label={t.navCards.sectionAria}>
  <div class="nav-cards__inner">
    <p class="nav-cards__eyebrow" data-reveal>{t.navCards.eyebrow}</p>
    <h2 class="nav-cards__heading">
      <span data-split data-reveal-chars>{t.navCards.heading}</span>
    </h2>

    <div class="nav-cards__grid">
      {
        cards.map((card) => (
          <a href={card.href} class="nav-card" data-nav-card data-accent={card.accent}>
            <span class="nav-card__icon" aria-hidden="true">
              {card.icon === 'planet' && (
                <svg viewBox="0 0 48 48" fill="none">
                  <ellipse
                    cx="24"
                    cy="26"
                    rx="20"
                    ry="6"
                    stroke="currentColor"
                    stroke-width="1.2"
                    opacity="0.5"
                  />
                  <circle
                    cx="24"
                    cy="22"
                    r="9"
                    stroke="currentColor"
                    stroke-width="1.5"
                    fill="rgba(255,255,255,0.04)"
                  />
                </svg>
              )}
              {card.icon === 'mountain' && (
                <svg viewBox="0 0 48 48" fill="none">
                  <path
                    d="M4 38 L18 18 L26 28 L34 14 L44 38 Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                  <circle cx="34" cy="14" r="2" fill="currentColor" opacity="0.7" />
                </svg>
              )}
              {card.icon === 'terminal' && (
                <svg viewBox="0 0 48 48" fill="none">
                  <rect
                    x="6"
                    y="10"
                    width="36"
                    height="28"
                    rx="3"
                    stroke="currentColor"
                    stroke-width="1.5"
                  />
                  <path
                    d="M14 22 L20 26 L14 30"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <line
                    x1="24"
                    y1="30"
                    x2="34"
                    y2="30"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                </svg>
              )}
            </span>
            <span class="nav-card__label">{card.label}</span>
            <span class="nav-card__desc">{card.description}</span>
            <span class="nav-card__arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    <footer class="site-footer">
      <span>{t.navCards.footerCopyright}</span>
      <span>{t.navCards.footerBuiltWith}</span>
    </footer>
  </div>
</section>

<style>
  .nav-cards {
    position: relative;
    padding: clamp(6rem, 14vh, 10rem) 1.5rem clamp(3rem, 6vh, 4rem);
  }

  .nav-cards__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .nav-cards__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1.5rem;
  }

  .nav-cards__heading {
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 4rem;
    color: #fff;
  }

  .nav-cards__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }
  .nav-cards__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .nav-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .nav-card {
    position: relative;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 1rem;
    padding: 2.25rem 2rem 1.75rem;
    text-decoration: none;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.025);
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.5s ease,
      background 0.5s ease;
  }

  .nav-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at top right,
      var(--accent-color, rgba(255, 255, 255, 0.1)) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .nav-card:hover,
  .nav-card:focus-visible {
    transform: translateY(-6px);
    outline: none;
  }

  .nav-card:hover::before,
  .nav-card:focus-visible::before {
    opacity: 1;
  }

  .nav-card[data-accent='projects'] {
    --accent-color: rgba(120, 170, 255, 0.25);
  }
  .nav-card[data-accent='projects']:hover {
    border-color: rgba(120, 170, 255, 0.5);
  }
  .nav-card[data-accent='projects'] .nav-card__icon {
    color: #80a8ff;
  }

  .nav-card[data-accent='experience'] {
    --accent-color: rgba(140, 200, 120, 0.22);
  }
  .nav-card[data-accent='experience']:hover {
    border-color: rgba(140, 200, 120, 0.5);
  }
  .nav-card[data-accent='experience'] .nav-card__icon {
    color: #a8d480;
  }

  .nav-card[data-accent='contact'] {
    --accent-color: rgba(74, 222, 128, 0.22);
  }
  .nav-card[data-accent='contact']:hover {
    border-color: rgba(74, 222, 128, 0.5);
  }
  .nav-card[data-accent='contact'] .nav-card__icon {
    color: #4ade80;
  }

  .nav-card__icon {
    width: 2.5rem;
    height: 2.5rem;
  }

  .nav-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .nav-card__label {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .nav-card__desc {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.55);
  }

  .nav-card__arrow {
    align-self: end;
    justify-self: end;
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.5);
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      color 0.4s ease;
  }

  .nav-card:hover .nav-card__arrow {
    transform: translateX(6px);
    color: #fff;
  }

  .site-footer {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 860px) {
    .nav-cards__grid {
      grid-template-columns: 1fr;
    }
    .site-footer {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>

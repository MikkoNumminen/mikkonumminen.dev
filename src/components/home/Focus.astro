---
import { asLocale, getTranslations } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);

const items = t.focus.items;
---

<section class="focus has-grain" aria-label={t.focus.sectionAria}>
  <span class="ghost-num focus__ghost" aria-hidden="true">02</span>

  <div class="focus__inner">
    <p class="focus__eyebrow eyebrow-marker" data-reveal>
      <span class="eyebrow-marker__num" aria-hidden="true">/ 02</span>
      <span class="eyebrow-marker__rule" aria-hidden="true"></span>
      {t.focus.eyebrow}
    </p>

    <h2 class="focus__heading">
      <span data-split data-reveal-chars>{t.focus.heading}</span>
    </h2>

    <ol class="focus__list">
      {
        items.map((item, idx) => (
          <li class="focus__row" data-reveal>
            <span class="focus__row-num" aria-hidden="true">
              0{idx + 1}
            </span>
            <div class="focus__row-body">
              <h3 class="focus__title">{item.title}</h3>
              <p class="focus__body">{item.body}</p>
            </div>
            <span class="focus__row-tick" aria-hidden="true" />
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .focus {
    position: relative;
    padding: clamp(7rem, 16vh, 12rem) 1.5rem;
    overflow: hidden;
  }

  .focus__ghost {
    top: 5rem;
    left: -3vw;
    color: rgba(128, 168, 255, 0.04);
  }

  .focus__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  .focus__eyebrow {
    margin: 0 0 1.5rem;
  }

  .focus__heading {
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.02;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 4rem;
    color: #fff;
    max-width: 22ch;
  }

  .focus__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }
  .focus__heading :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }
  .focus__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .focus__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .focus__row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr auto;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: baseline;
    padding: clamp(2rem, 4vh, 3rem) 0.5rem clamp(2rem, 4vh, 3rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.4s ease;
  }

  .focus__row:hover {
    background: linear-gradient(
      to right,
      rgba(128, 168, 255, 0.04),
      transparent 70%
    );
  }

  .focus__row-num {
    font-family: var(--font-mono);
    font-size: clamp(3.5rem, 9vw, 6.5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.85;
    color: rgba(128, 168, 255, 0.18);
    transition: color 0.4s ease;
    align-self: center;
  }

  .focus__row:hover .focus__row-num {
    color: rgba(128, 168, 255, 0.55);
  }

  .focus__row-body {
    align-self: center;
    max-width: 56ch;
  }

  .focus__title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #fff;
    margin: 0 0 0.85rem;
    line-height: 1.2;
  }

  .focus__body {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .focus__row-tick {
    align-self: center;
    width: 0.5rem;
    height: 0.5rem;
    border-right: 1px solid rgba(128, 168, 255, 0.4);
    border-top: 1px solid rgba(128, 168, 255, 0.4);
    transform: rotate(45deg);
    opacity: 0.4;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease;
  }

  .focus__row:hover .focus__row-tick {
    transform: translateX(6px) rotate(45deg);
    opacity: 1;
  }

  @media (max-width: 720px) {
    .focus__row {
      grid-template-columns: auto 1fr;
      gap: 1.25rem 1.5rem;
      align-items: start;
    }

    .focus__row-num {
      font-size: clamp(2.5rem, 12vw, 4rem);
      grid-row: 1;
    }

    .focus__row-body {
      grid-row: 1 / 3;
      grid-column: 2;
    }

    .focus__row-tick {
      display: none;
    }

    .focus__ghost {
      left: -8vw;
      font-size: clamp(7rem, 30vw, 12rem);
    }
  }
</style>

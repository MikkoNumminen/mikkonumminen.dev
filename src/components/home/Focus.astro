---
const items = [
  {
    title: 'Production-grade',
    body: 'Tested, observable, and built to be operated. Every feature ships with the seams that let it survive contact with real users.',
  },
  {
    title: 'AI-native workflows',
    body: 'Pair-programming with AI is part of the toolchain. The output still has to be code I would defend in a review.',
  },
  {
    title: 'End-to-end',
    body: 'From schema to pixel. Backend, frontend, infra, deployment — same person, same standard.',
  },
];
---

<section class="focus" aria-label="What I focus on">
  <div class="focus__inner">
    <p class="focus__eyebrow" data-reveal>focus</p>
    <h2 class="focus__heading">
      <span data-split data-reveal-chars>How I work.</span>
    </h2>

    <ol class="focus__list">
      {
        items.map((item, idx) => (
          <li class="focus__item" data-reveal>
            <span class="focus__index">0{idx + 1}</span>
            <h3 class="focus__title">{item.title}</h3>
            <p class="focus__body">{item.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .focus {
    position: relative;
    padding: clamp(7rem, 16vh, 12rem) 1.5rem;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(10, 14, 28, 0.6) 30%,
      rgba(10, 14, 28, 0.6) 70%,
      transparent
    );
  }

  .focus__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .focus__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1.5rem;
  }

  .focus__heading {
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 4rem;
    color: #fff;
  }

  .focus__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }
  .focus__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .focus__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .focus__item {
    position: relative;
    padding: 2rem 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(4px);
    transition: border-color 0.4s ease, transform 0.4s ease, background 0.4s ease;
  }

  .focus__item:hover {
    border-color: rgba(128, 168, 255, 0.35);
    transform: translateY(-4px);
    background: rgba(128, 168, 255, 0.05);
  }

  .focus__index {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: #80a8ff;
    margin-bottom: 1.5rem;
  }

  .focus__title {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0 0 0.75rem;
  }

  .focus__body {
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 860px) {
    .focus__list {
      grid-template-columns: 1fr;
    }
  }
</style>

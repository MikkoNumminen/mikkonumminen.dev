---
import { asLocale, getTranslations } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
---

<section class="velocity has-grain" aria-label={t.velocity.sectionAria}>
  <span class="ghost-num velocity__ghost" aria-hidden="true">04</span>

  <div class="velocity__inner">
    <p class="velocity__eyebrow eyebrow-marker" data-reveal>
      <span class="eyebrow-marker__num" aria-hidden="true">/ 04</span>
      <span class="eyebrow-marker__rule" aria-hidden="true"></span>
      {t.velocity.eyebrow}
    </p>

    <h2 class="velocity__heading">
      <span data-split data-reveal-chars>{t.velocity.heading}</span>
    </h2>

    <p class="velocity__body" data-reveal>{t.velocity.body}</p>

    <hr class="hairline velocity__divider" aria-hidden="true" data-reveal />

    <div class="velocity__stats">
      {
        t.velocity.stats.map((stat, idx) => (
          <div
            class="velocity__stat"
            data-reveal
            data-rank={idx === 0 ? 'lead' : 'support'}
          >
            <span class="velocity__stat-num">{stat.num}</span>
            <span class="velocity__stat-label">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .velocity {
    position: relative;
    padding: clamp(7rem, 16vh, 11rem) 1.5rem;
    overflow: hidden;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(28, 18, 8, 0.45) 30%,
      rgba(28, 18, 8, 0.45) 70%,
      transparent
    );
  }

  .velocity__ghost {
    top: 5rem;
    left: -3vw;
    color: rgba(251, 191, 36, 0.05);
  }

  .velocity__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  .velocity__eyebrow {
    margin: 0 0 1.5rem;
  }

  .velocity__heading {
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.02;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 1.75rem;
    color: #fff;
    max-width: 18ch;
  }

  .velocity__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }
  .velocity__heading :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }
  .velocity__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .velocity__body {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 64ch;
    margin: 0;
  }

  .velocity__divider {
    margin: 4rem 0 0;
  }

  .velocity__stats {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-top: 3rem;
    align-items: end;
  }

  .velocity__stat {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    padding-right: 1.25rem;
  }

  .velocity__stat + .velocity__stat::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(251, 191, 36, 0.18) 30%,
      rgba(251, 191, 36, 0.18) 70%,
      transparent
    );
  }

  .velocity__stat-num {
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: #fbbf24;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
  }

  .velocity__stat[data-rank='lead'] .velocity__stat-num {
    font-size: clamp(4.5rem, 11vw, 8rem);
  }

  .velocity__stat[data-rank='support'] .velocity__stat-num {
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    color: rgba(251, 191, 36, 0.85);
  }

  .velocity__stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    max-width: 24ch;
  }

  @media (max-width: 720px) {
    .velocity__stats {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: stretch;
    }

    .velocity__stat + .velocity__stat::before {
      left: 0;
      top: -1.25rem;
      bottom: auto;
      right: 0;
      width: auto;
      height: 1px;
      background: linear-gradient(
        to right,
        rgba(251, 191, 36, 0.2),
        transparent 70%
      );
    }

    .velocity__ghost {
      left: -8vw;
      font-size: clamp(7rem, 30vw, 12rem);
    }
  }
</style>

---
import { asLocale, getTranslations } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);

const items = t.integrations.items;
---

<section class="integrations has-grain" aria-label={t.integrations.sectionAria}>
  <span class="ghost-num integrations__ghost" aria-hidden="true">03</span>

  <div class="integrations__inner">
    <p class="integrations__eyebrow eyebrow-marker" data-reveal>
      <span class="eyebrow-marker__num" aria-hidden="true">/ 03</span>
      <span class="eyebrow-marker__rule" aria-hidden="true"></span>
      {t.integrations.eyebrow}
    </p>

    <h2 class="integrations__heading">
      <span data-split data-reveal-chars>{t.integrations.heading}</span>
    </h2>

    <ul class="integrations__list">
      {
        items.map((item) => (
          <li class="integrations__row" data-reveal>
            <div class="integrations__row-head">
              <span class="integrations__project">{item.project}</span>
              <span class="integrations__connector" aria-hidden="true" />
              <span class="integrations__api">{item.api}</span>
            </div>
            <p class="integrations__body">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .integrations {
    position: relative;
    padding: clamp(7rem, 16vh, 11rem) 1.5rem;
    overflow: hidden;
  }

  .integrations__ghost {
    top: 4rem;
    right: -2vw;
    color: rgba(251, 191, 36, 0.04);
  }

  .integrations__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
  }

  .integrations__eyebrow {
    margin: 0 0 1.5rem;
  }

  .integrations__heading {
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.02;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 4rem;
    color: #fff;
    max-width: 22ch;
  }

  .integrations__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }
  .integrations__heading :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }
  .integrations__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .integrations__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .integrations__row {
    position: relative;
    padding: clamp(1.75rem, 3.5vh, 2.75rem) 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.4s ease;
  }

  .integrations__row:hover {
    background: linear-gradient(
      to right,
      rgba(251, 191, 36, 0.04),
      transparent 70%
    );
  }

  .integrations__row-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .integrations__project {
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }

  .integrations__connector {
    flex: 1 1 1.5rem;
    min-width: 1.5rem;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0.18),
      rgba(251, 191, 36, 0.35)
    );
    align-self: center;
    transform: translateY(-1px);
  }

  .integrations__api {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: #fbbf24;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(251, 191, 36, 0.08);
    border: 1px solid rgba(251, 191, 36, 0.28);
    white-space: nowrap;
  }

  .integrations__body {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    max-width: 78ch;
  }

  @media (max-width: 720px) {
    .integrations__connector {
      display: none;
    }
    .integrations__row-head {
      gap: 0.75rem;
    }
    .integrations__ghost {
      right: -6vw;
      font-size: clamp(7rem, 28vw, 12rem);
    }
  }
</style>

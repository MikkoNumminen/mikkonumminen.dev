---
import { asLocale, getTranslations } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
---

<section class="intro has-grain" aria-label={t.intro.sectionAria}>
  <span class="ghost-num intro__ghost" aria-hidden="true">01</span>

  <div class="intro__inner">
    <p class="intro__eyebrow eyebrow-marker" data-reveal>
      <span class="eyebrow-marker__num" aria-hidden="true">/ 01</span>
      <span class="eyebrow-marker__rule" aria-hidden="true"></span>
      {t.intro.eyebrow}
    </p>

    <h2 class="intro__heading">
      <span data-split data-reveal-chars>{t.intro.heading}</span>
    </h2>

    <p class="intro__body" data-reveal>
      {t.intro.body}
    </p>

    <hr class="hairline intro__divider" aria-hidden="true" data-reveal />

    <div class="intro__stats" role="list">
      <div class="intro__stat" data-reveal data-stat="tests" role="listitem">
        <span class="intro__stat-num">
          1828<span class="intro__stat-suffix">+</span>
        </span>
        <span class="intro__stat-label">{t.intro.statTests}</span>
      </div>
      <div class="intro__stat" data-reveal data-stat="coverage" role="listitem">
        <span class="intro__stat-num">
          91.9<span class="intro__stat-suffix">%</span>
        </span>
        <span class="intro__stat-label">{t.intro.statCoverage}</span>
      </div>
      <div class="intro__stat" data-reveal data-stat="products" role="listitem">
        <span class="intro__stat-num">7</span>
        <span class="intro__stat-label">{t.intro.statProducts}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .intro {
    position: relative;
    padding: clamp(8rem, 18vh, 14rem) 1.5rem clamp(6rem, 12vh, 9rem);
    overflow: hidden;
  }

  .intro__ghost {
    top: 4rem;
    right: -2vw;
  }

  .intro__inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    gap: 2rem;
  }

  .intro__eyebrow {
    margin: 0;
  }

  .intro__heading {
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.02;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0;
    color: #fff;
    max-width: 18ch;
  }

  .intro__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }

  .intro__heading :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }

  .intro__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .intro__body {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 62ch;
    margin: 0;
  }

  .intro__divider {
    margin: 4.5rem 0 0;
  }

  .intro__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 2.5rem;
  }

  .intro__stat {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-right: 1.5rem;
    position: relative;
  }

  /* Subtle vertical hairlines between stats on desktop */
  .intro__stat + .intro__stat::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(255, 255, 255, 0.12) 30%,
      rgba(255, 255, 255, 0.12) 70%,
      transparent
    );
  }

  .intro__stat-num {
    font-size: clamp(3.25rem, 8vw, 5.75rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
  }

  .intro__stat-suffix {
    font-size: 0.55em;
    font-weight: 600;
    letter-spacing: 0;
    margin-left: 0.05em;
    vertical-align: 0.2em;
  }

  .intro__stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.45;
    max-width: 22ch;
  }

  /* Per-stat color story — previews the rest of the site's palette
     (home / projects / velocity-amber). */
  .intro__stat[data-stat='tests'] .intro__stat-num {
    color: var(--color-home-accent);
  }
  .intro__stat[data-stat='tests'] .intro__stat-suffix {
    color: rgba(196, 212, 255, 0.65);
  }

  .intro__stat[data-stat='coverage'] .intro__stat-num {
    color: var(--color-projects-accent);
  }
  .intro__stat[data-stat='coverage'] .intro__stat-suffix {
    color: rgba(128, 168, 255, 0.65);
  }

  .intro__stat[data-stat='products'] .intro__stat-num {
    color: #fbbf24;
  }

  @media (max-width: 720px) {
    .intro__stats {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .intro__stat + .intro__stat::before {
      left: 0;
      top: -1.25rem;
      bottom: auto;
      right: 0;
      width: auto;
      height: 1px;
      background: linear-gradient(
        to right,
        rgba(255, 255, 255, 0.12),
        transparent 70%
      );
    }

    .intro__ghost {
      top: 2rem;
      right: -4vw;
      font-size: clamp(7rem, 28vw, 12rem);
    }
  }
</style>

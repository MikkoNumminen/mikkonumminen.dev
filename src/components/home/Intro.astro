---
---

<section class="intro" aria-label="About">
  <div class="intro__grid">
    <p class="intro__eyebrow" data-reveal>about</p>

    <h2 class="intro__heading">
      <span data-split data-reveal-chars>I build production web applications.</span>
    </h2>

    <p class="intro__body" data-reveal>
      Full-stack developer based in Finland. I work end-to-end —
      architecture, infrastructure, code, polish — with AI-assisted
      workflows that let small teams ship like big ones.
    </p>
  </div>

  <div class="intro__stats">
    <div class="intro__stat" data-reveal>
      <span class="intro__stat-num">1100<span class="intro__stat-plus">+</span></span>
      <span class="intro__stat-label">tests across flagship project</span>
    </div>
    <div class="intro__stat" data-reveal>
      <span class="intro__stat-num">99.5<span class="intro__stat-plus">%</span></span>
      <span class="intro__stat-label">code coverage maintained</span>
    </div>
    <div class="intro__stat" data-reveal>
      <span class="intro__stat-num">3</span>
      <span class="intro__stat-label">live products in production</span>
    </div>
  </div>
</section>

<style>
  .intro {
    position: relative;
    padding: clamp(8rem, 18vh, 14rem) 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .intro__grid {
    display: grid;
    gap: 2rem;
    max-width: 740px;
  }

  .intro__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .intro__heading {
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
    color: #fff;
  }

  .intro__heading :global([data-split]) {
    display: inline-block;
    overflow: hidden;
  }

  .intro__heading :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  .intro__body {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 580px;
    margin: 0;
  }

  .intro__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 6rem;
    padding-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .intro__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .intro__stat-num {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
  }

  .intro__stat-plus {
    color: #80a8ff;
    margin-left: 0.1ch;
  }

  .intro__stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 720px) {
    .intro__stats {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }
</style>

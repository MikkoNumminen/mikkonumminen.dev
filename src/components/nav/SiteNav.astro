---
import {
  asLocale,
  getTranslations,
  localizePath,
  stripLocale,
  LOCALES,
  type Locale,
} from '../../i18n';

interface Props {
  theme: 'home' | 'projects' | 'experience' | 'contact';
  current: string;
  locale?: Locale;
}

const { theme, current, locale: propLocale } = Astro.props;
const locale = propLocale ?? asLocale(Astro.currentLocale);
const t = getTranslations(locale);

const links = [
  { href: localizePath('/', locale), label: t.nav.home },
  { href: localizePath('/projects', locale), label: t.nav.projects },
  { href: localizePath('/experience', locale), label: t.nav.experience },
  { href: localizePath('/contact', locale), label: t.nav.contact },
];

// For the language switcher we need to know the bare path (no locale prefix)
// so we can re-localize it for each available language.
const barePath = stripLocale(current);
const langLinks = LOCALES.map((l) => ({
  locale: l,
  href: localizePath(barePath, l),
  label: t.langSwitcher[l],
  isCurrent: l === locale,
}));

const isActive = (href: string) => {
  if (href === '/' || href === '/fi/' || href === '/sv/') {
    return current === href;
  }
  return current === href || current.startsWith(href + '/');
};
---

<nav
  aria-label={t.nav.primaryAria}
  data-theme={theme}
  class="site-nav fixed left-1/2 -translate-x-1/2 z-50 px-2 py-2 rounded-full backdrop-blur-md border"
>
  <ul class="flex items-center gap-1 text-xs sm:text-sm">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class="site-nav__link px-4 py-3 sm:px-3 sm:py-1.5 rounded-full transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))
    }

    <li class="site-nav__divider" aria-hidden="true"></li>

    <li>
      <ul
        class="site-nav__langs flex items-center gap-1 sm:gap-0.5"
        aria-label={t.nav.languageSwitcherAria}
      >
        {
          langLinks.map((l) => (
            <li>
              <a
                href={l.href}
                hreflang={l.locale}
                aria-current={l.isCurrent ? 'page' : undefined}
                data-lang={l.locale}
                class="site-nav__lang px-3 py-2 sm:px-2 sm:py-1 rounded-full transition-colors"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </li>
  </ul>
</nav>

<script>
  // When the user manually picks a language, remember it so the auto-detect
  // script in BaseLayout doesn't override their choice on the next visit.
  document.querySelectorAll<HTMLAnchorElement>('.site-nav__lang').forEach((a) => {
    a.addEventListener('click', () => {
      const lang = a.getAttribute('data-lang');
      if (lang) {
        try {
          localStorage.setItem('mn_preferred_locale', lang);
          // Also clear the session flag so the detector won't re-fire
          // before the navigation completes.
          sessionStorage.setItem('mn_lang_checked', '1');
        } catch (e) {
          /* ignore */
        }
      }
    });
  });
</script>

<style>
  .site-nav {
    font-family: var(--font-mono);
    /* Push the nav below the notch on devices with viewport-fit=cover.
       Falls back to 1rem (the original top-4) on non-notched devices. */
    top: calc(env(safe-area-inset-top, 0px) + 1rem);
    transition:
      background-color 0.4s ease,
      border-color 0.4s ease,
      color 0.4s ease;
  }

  .site-nav__divider {
    width: 1px;
    height: 1.1rem;
    margin: 0 0.35rem;
    background: currentColor;
    opacity: 0.18;
  }

  .site-nav__langs {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav__lang {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.8;
    text-decoration: none;
    color: inherit;
  }

  .site-nav__lang:hover {
    opacity: 1;
  }

  .site-nav__lang[aria-current='page'] {
    opacity: 1;
    font-weight: 600;
  }

  /* Default (home) */
  .site-nav[data-theme='home'] {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
  }
  .site-nav[data-theme='home'] .site-nav__link:hover,
  .site-nav[data-theme='home'] .site-nav__link[aria-current='page'] {
    background-color: rgba(255, 255, 255, 0.14);
    color: #fff;
  }
  .site-nav[data-theme='home'] .site-nav__lang[aria-current='page'] {
    background-color: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  /* Projects (space blue) */
  .site-nav[data-theme='projects'] {
    background-color: rgba(20, 30, 60, 0.55);
    border-color: rgba(120, 170, 255, 0.35);
    color: #c4d4ff;
    box-shadow: 0 0 24px rgba(80, 130, 255, 0.25);
  }
  .site-nav[data-theme='projects'] .site-nav__link:hover,
  .site-nav[data-theme='projects'] .site-nav__link[aria-current='page'] {
    background-color: rgba(120, 170, 255, 0.18);
    color: #fff;
  }
  .site-nav[data-theme='projects'] .site-nav__lang[aria-current='page'] {
    background-color: rgba(120, 170, 255, 0.18);
    color: #fff;
  }

  /* Experience (earthy green) */
  .site-nav[data-theme='experience'] {
    background-color: rgba(34, 50, 30, 0.6);
    border-color: rgba(140, 180, 100, 0.4);
    color: #d8e8c0;
  }
  .site-nav[data-theme='experience'] .site-nav__link:hover,
  .site-nav[data-theme='experience'] .site-nav__link[aria-current='page'] {
    background-color: rgba(140, 180, 100, 0.2);
    color: #fff;
  }
  .site-nav[data-theme='experience'] .site-nav__lang[aria-current='page'] {
    background-color: rgba(140, 180, 100, 0.2);
    color: #fff;
  }

  /* Contact (terminal green) */
  .site-nav[data-theme='contact'] {
    background-color: rgba(5, 15, 8, 0.85);
    border-color: rgba(74, 222, 128, 0.4);
    color: var(--color-term-green);
    box-shadow: 0 0 20px rgba(74, 222, 128, 0.18);
  }
  .site-nav[data-theme='contact'] .site-nav__link:hover,
  .site-nav[data-theme='contact'] .site-nav__link[aria-current='page'] {
    background-color: rgba(74, 222, 128, 0.18);
    color: var(--color-term-green-bright);
    text-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
  }
  .site-nav[data-theme='contact'] .site-nav__lang[aria-current='page'] {
    background-color: rgba(74, 222, 128, 0.18);
    color: var(--color-term-green-bright);
  }
</style>

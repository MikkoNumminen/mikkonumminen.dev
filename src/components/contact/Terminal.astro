---
import '../../styles/terminal.css';
import { asLocale, getTranslations } from '../../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);

const prompt = 'guest@mikkonumminen:~$';
---

<div class="crt">
  <h1 class="sr-only">{t.contactPage.h1}</h1>
  <div class="crt__vignette" aria-hidden="true"></div>
  <div class="crt__scanlines" aria-hidden="true"></div>
  <div class="crt__flicker" aria-hidden="true"></div>

  <section
    class="terminal"
    aria-label={t.contactPage.interactiveAria}
    data-prompt={prompt}
  >
    <header class="terminal__chrome" aria-hidden="true">
      <div class="terminal__dots">
        <span class="terminal__dot terminal__dot--red"></span>
        <span class="terminal__dot terminal__dot--amber"></span>
        <span class="terminal__dot terminal__dot--green"></span>
      </div>
      <div class="terminal__title">{t.contactPage.windowTitle}</div>
      <div class="terminal__chrome-spacer"></div>
    </header>

    <div class="terminal__screen">
      <div
        class="terminal__output"
        id="terminal-output"
        role="log"
        aria-live="polite"
        aria-atomic="false"
      >
      </div>

      <form class="terminal__form" id="terminal-form" autocomplete="off">
        <label for="terminal-input" class="terminal__prompt">
          <span class="terminal__user">guest@mikkonumminen</span><span
            class="terminal__sep">:</span
          ><span class="terminal__path">~</span><span class="terminal__sigil">$</span>
        </label>
        <span class="terminal__input-wrap">
          <input
            id="terminal-input"
            class="terminal__input"
            type="text"
            spellcheck="false"
            autocapitalize="off"
            autocorrect="off"
            inputmode="text"
            aria-label={t.contactPage.inputAria}
          />
          <span class="terminal__cursor" aria-hidden="true"></span>
        </span>
      </form>

      <div class="terminal__hints" aria-hidden="true">
        <span>{t.contactPage.hintType} <kbd>help</kbd></span>
        <span><kbd>↑</kbd>/<kbd>↓</kbd> {t.contactPage.hintHistory}</span>
        <span><kbd>tab</kbd> {t.contactPage.hintComplete}</span>
      </div>
    </div>
  </section>

  <noscript>
    <section class="terminal__noscript">
      <h1>{t.contactPage.h1}</h1>
      <p>{t.contactPage.noscriptIntro}</p>
      <p>{t.contactPage.noscriptReachMe}</p>
      <ul>
        <li>
          {t.contactPage.noscriptEmailLabel}
          <a href="mailto:numminen.mikko.petteri@gmail.com"
            >numminen.mikko.petteri@gmail.com</a
          >
        </li>
        <li>
          {t.contactPage.noscriptGithubLabel}
          <a href="https://github.com/MikkoNumminen">github.com/MikkoNumminen</a>
        </li>
      </ul>
    </section>
  </noscript>
</div>

---
import { projects } from '../../data/projects';
---

<section class="project-grid" aria-label="Projects">
  <header class="project-grid__header">
    <p class="project-grid__eyebrow">selected work</p>
    <h1 class="project-grid__title">Projects</h1>
    <p class="project-grid__lede">
      Things I have built. The desktop view shows them as an interactive solar
      system — here is the readable list.
    </p>
  </header>

  <ul class="project-grid__list">
    {
      projects.map((p) => (
        <li class="project-card" data-accent={p.color}>
          <div class="project-card__head">
            <span class="project-card__dot" style={`background:${p.color}`} />
            <h2 class="project-card__name">{p.name}</h2>
            {p.status && (
              <span class="project-card__status" data-status={p.status}>
                {p.status}
              </span>
            )}
          </div>

          <p class="project-card__tagline">{p.tagline}</p>
          <p class="project-card__description">{p.description}</p>

          {p.highlights && (
            <ul class="project-card__highlights">
              {p.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}

          <ul class="project-card__tech">
            {p.tech.map((t) => (
              <li>{t}</li>
            ))}
          </ul>

          <div class="project-card__links">
            {p.liveUrl && (
              <a
                href={p.liveUrl}
                class="project-card__link primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                live demo →
              </a>
            )}
            {p.githubUrl && (
              <a
                href={p.githubUrl}
                class="project-card__link secondary"
                target="_blank"
                rel="noopener noreferrer"
              >
                github
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .project-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 7rem 1.5rem 4rem;
    color: #e6ecff;
  }

  .project-grid__header {
    margin-bottom: 3.5rem;
    max-width: 640px;
  }

  .project-grid__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(196, 212, 255, 0.5);
    margin: 0 0 1rem;
  }

  .project-grid__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .project-grid__lede {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(230, 236, 255, 0.65);
    margin: 0;
  }

  .project-grid__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    padding: 1.75rem 1.75rem 1.5rem;
    border: 1px solid rgba(120, 170, 255, 0.16);
    border-radius: 14px;
    background: rgba(10, 18, 38, 0.55);
    backdrop-filter: blur(6px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .project-card:hover {
    border-color: rgba(120, 170, 255, 0.35);
    transform: translateY(-3px);
  }

  .project-card__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-card__dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 999px;
    box-shadow: 0 0 12px currentColor;
  }

  .project-card__name {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }

  .project-card__status {
    margin-left: auto;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid rgba(196, 212, 255, 0.35);
    color: #c4d4ff;
  }

  .project-card__status[data-status='live'] {
    border-color: rgba(74, 222, 128, 0.5);
    color: #86efac;
  }
  .project-card__status[data-status='wip'] {
    border-color: rgba(251, 191, 36, 0.45);
    color: #fcd34d;
  }

  .project-card__tagline {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(196, 212, 255, 0.65);
    margin: 0;
  }

  .project-card__description {
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(230, 236, 255, 0.75);
    margin: 0;
  }

  .project-card__highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-card__highlights li {
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(120, 170, 255, 0.08);
    border: 1px solid rgba(120, 170, 255, 0.18);
    font-size: 0.7rem;
    color: #c4d4ff;
  }

  .project-card__tech {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .project-card__tech li {
    padding: 0.25rem 0.55rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(230, 236, 255, 0.7);
  }

  .project-card__links {
    margin-top: auto;
    display: flex;
    gap: 0.5rem;
  }

  .project-card__link {
    flex: 1;
    text-align: center;
    padding: 0.65rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    transition: all 0.25s ease;
  }

  .project-card__link.primary {
    background: rgba(120, 170, 255, 0.18);
    border: 1px solid rgba(120, 170, 255, 0.45);
    color: #fff;
  }
  .project-card__link.primary:hover {
    background: rgba(120, 170, 255, 0.3);
  }
  .project-card__link.secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(230, 236, 255, 0.8);
  }
  .project-card__link.secondary:hover {
    background: rgba(255, 255, 255, 0.05);
  }
</style>

---
import { asLocale, getTranslations } from '../../i18n';

const t = getTranslations(asLocale(Astro.currentLocale));
---

<aside
  class="project-detail"
  id="project-detail"
  data-open="false"
  aria-hidden="true"
  aria-label={t.projectsPage.detailAria}
>
  <button
    type="button"
    class="project-detail__close"
    id="project-detail-close"
    aria-label={t.projectsPage.closeAria}
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path
        d="M5 5 L15 15 M15 5 L5 15"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"></path>
    </svg>
  </button>

  <div class="project-detail__inner">
    <span class="project-detail__status" data-field="status"></span>
    <h2 class="project-detail__name" data-field="name"></h2>
    <p class="project-detail__tagline" data-field="tagline"></p>

    <p class="project-detail__description" data-field="description"></p>

    <div class="project-detail__highlights" data-field="highlights"></div>

    <div class="project-detail__tech-wrap">
      <p class="project-detail__label">{t.projectsPage.techLabel}</p>
      <ul class="project-detail__tech" data-field="tech"></ul>
    </div>

    <div class="project-detail__links" data-field="links"></div>
  </div>
</aside>

<style>
  .project-detail {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: min(440px, 95vw);
    z-index: 40;
    background: linear-gradient(
      to left,
      rgba(8, 14, 32, 0.92),
      rgba(8, 14, 32, 0.78) 70%,
      rgba(8, 14, 32, 0)
    );
    backdrop-filter: blur(12px);
    color: #e6ecff;
    padding: 6rem 2.5rem 2.5rem 2.5rem;
    transform: translateX(40px);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 0.55s ease;
    overflow-y: auto;
    border-left: 1px solid rgba(120, 170, 255, 0.18);
  }

  .project-detail[data-open='true'] {
    transform: translateX(0);
    opacity: 1;
    pointer-events: auto;
  }

  .project-detail__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgba(120, 170, 255, 0.35);
    background: rgba(120, 170, 255, 0.08);
    color: #c4d4ff;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .project-detail__close:hover {
    background: rgba(120, 170, 255, 0.18);
    border-color: rgba(120, 170, 255, 0.6);
    transform: rotate(90deg);
  }

  .project-detail__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .project-detail__status {
    align-self: flex-start;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid rgba(120, 170, 255, 0.35);
    color: #c4d4ff;
  }

  .project-detail__status[data-status='live'] {
    border-color: rgba(74, 222, 128, 0.5);
    color: #86efac;
    background: rgba(74, 222, 128, 0.08);
  }

  .project-detail__status[data-status='wip'] {
    border-color: rgba(251, 191, 36, 0.45);
    color: #fcd34d;
    background: rgba(251, 191, 36, 0.06);
  }

  .project-detail__name {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .project-detail__tagline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: rgba(196, 212, 255, 0.7);
    margin: 0;
  }

  .project-detail__description {
    font-size: 0.98rem;
    line-height: 1.6;
    color: rgba(230, 236, 255, 0.78);
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(120, 170, 255, 0.12);
  }

  .project-detail__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-detail__highlights :global(.highlight) {
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    background: rgba(120, 170, 255, 0.08);
    border: 1px solid rgba(120, 170, 255, 0.2);
    font-size: 0.75rem;
    color: #c4d4ff;
  }

  .project-detail__label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(196, 212, 255, 0.45);
    margin: 0 0 0.5rem;
  }

  .project-detail__tech {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-detail__tech :global(li) {
    padding: 0.3rem 0.65rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(230, 236, 255, 0.8);
  }

  .project-detail__links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .project-detail__links :global(a) {
    flex: 1;
    text-align: center;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .project-detail__links :global(a.primary) {
    background: rgba(120, 170, 255, 0.18);
    border: 1px solid rgba(120, 170, 255, 0.5);
    color: #fff;
  }

  .project-detail__links :global(a.primary:hover) {
    background: rgba(120, 170, 255, 0.3);
    border-color: rgba(120, 170, 255, 0.8);
    transform: translateY(-2px);
  }

  .project-detail__links :global(a.secondary) {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(230, 236, 255, 0.8);
  }

  .project-detail__links :global(a.secondary:hover) {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
  }

  @media (max-width: 720px) {
    .project-detail {
      width: 100vw;
      padding: 5rem 1.5rem 2rem;
    }
  }
</style>

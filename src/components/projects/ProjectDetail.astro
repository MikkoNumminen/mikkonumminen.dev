---
import '../../styles/project-detail.css';
import { asLocale, getTranslations } from '../../i18n';

const t = getTranslations(asLocale(Astro.currentLocale));
---

<section
  class="project-detail"
  id="project-detail"
  role="dialog"
  aria-modal="true"
  aria-labelledby="project-detail-name"
  data-open="false"
  aria-hidden="true"
  tabindex="-1"
>
  <button
    type="button"
    class="project-detail__close"
    id="project-detail-close"
    aria-label={t.projectsPage.closeAria}
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
      focusable="false"
    >
      <path
        d="M5 5 L15 15 M15 5 L5 15"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"></path>
    </svg>
  </button>

  <div class="project-detail__inner">
    <span class="project-detail__status" data-field="status"></span>
    <h2
      class="project-detail__name"
      id="project-detail-name"
      data-field="name"
      data-empty="true"
    >
    </h2>
    <p class="project-detail__tagline" data-field="tagline"></p>

    <p class="project-detail__description" data-field="description"></p>

    <div class="project-detail__highlights" data-field="highlights"></div>

    <div
      class="project-detail__externalApis-wrap"
      data-field="externalApisWrap"
      hidden
    >
      <p class="project-detail__label">{t.projectsPage.externalApisLabel}</p>
      <ul class="project-detail__externalApis" data-field="externalApis"></ul>
    </div>

    <div class="project-detail__tech-wrap">
      <p class="project-detail__label">{t.projectsPage.techLabel}</p>
      <ul class="project-detail__tech" data-field="tech"></ul>
    </div>

    <div class="project-detail__links" data-field="links"></div>
  </div>
</section>

---
import '../styles/projects-scene.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectDetail from '../components/projects/ProjectDetail.astro';
import ProjectGrid from '../components/projects/ProjectGrid.astro';
import { asLocale, getTranslations } from '../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
---

<BaseLayout
  title={t.meta.projects.title}
  description={t.meta.projects.description}
  theme="projects"
  ogImage="/og-projects.png"
>
  <!-- Desktop / capable: WebGL solar system. Visible by default; hidden via
       CSS on small viewports / reduced motion so the layout is stable before
       JS runs. The fallback grid is shown via the same CSS rules. -->
  <div class="projects-scene" data-projects-scene>
    <canvas id="projects-canvas" class="projects-scene__canvas" aria-hidden="true"
    ></canvas>

    <header class="projects-scene__intro" data-intro>
      <p class="projects-scene__eyebrow">{t.projectsPage.eyebrow}</p>
      <h1 class="projects-scene__title">{t.projectsPage.title}</h1>
      <p class="projects-scene__lede">
        {t.projectsPage.lede}
      </p>
    </header>

    <div class="projects-scene__legend" data-legend aria-hidden="true">
      <span><kbd>hover</kbd> {t.projectsPage.legendHover}</span>
      <span><kbd>click</kbd> {t.projectsPage.legendClick}</span>
    </div>

    <div class="hover-label" id="hover-label" data-visible="false" aria-hidden="true">
    </div>

    <ProjectDetail />
  </div>

  <!-- Mobile / no-JS / reduced-motion fallback -->
  <noscript>
    <ProjectGrid />
  </noscript>

  <div class="projects-fallback" data-projects-fallback hidden>
    <ProjectGrid />
  </div>
</BaseLayout>

<script>
  import { localizeProjects, type LocalizedProject } from '../data/projects';
  import { asLocale, getTranslations } from '../i18n';

  // Read locale from <html lang> set by BaseLayout, then merge structural
  // project data with the localized text from the i18n dictionaries.
  const locale = asLocale(document.documentElement.lang);
  const t = getTranslations(locale);
  const localizedProjects = localizeProjects(t);
  const tp = t.projectsPage;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isSmall = window.matchMedia('(max-width: 860px)').matches;

  let sceneHandle: {
    selectById: (id: string | null) => void;
    dispose: () => void;
  } | null = null;

  const sceneRoot = document.querySelector<HTMLElement>('[data-projects-scene]');
  const fallback = document.querySelector<HTMLElement>('[data-projects-fallback]');

  const start = async () => {
    if (reducedMotion || isSmall || !sceneRoot) {
      // CSS already hides the scene and shows the fallback grid for these
      // clients; the JS-side toggle remains as a safety net.
      if (sceneRoot) sceneRoot.hidden = true;
      if (fallback) fallback.hidden = false;
      return;
    }

    const canvas = document.getElementById('projects-canvas') as HTMLCanvasElement | null;
    const hoverLabel = document.getElementById('hover-label');
    const detail = document.getElementById('project-detail');
    const closeBtn = document.getElementById(
      'project-detail-close',
    ) as HTMLButtonElement | null;
    const intro = document.querySelector<HTMLElement>('[data-intro]');
    const legend = document.querySelector<HTMLElement>('[data-legend]');

    if (!canvas || !hoverLabel || !detail || !closeBtn) return;

    // Track the element that opened the drawer so we can restore focus.
    let lastFocused: HTMLElement | null = null;

    const getFocusable = (): HTMLElement[] => {
      return Array.from(
        detail.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
        ),
      ).filter((el) => !el.hasAttribute('disabled') && el.offsetParent !== null);
    };

    const trapTab = (e: KeyboardEvent) => {
      if (e.key !== 'Tab') return;
      const focusable = getFocusable();
      if (focusable.length === 0) {
        e.preventDefault();
        closeBtn.focus();
        return;
      }
      const first = focusable[0]!;
      const last = focusable[focusable.length - 1]!;
      const active = document.activeElement as HTMLElement | null;
      if (e.shiftKey) {
        if (active === first || !detail.contains(active)) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };

    const populateDetail = (p: LocalizedProject) => {
      const setText = (sel: string, text: string) => {
        const el = detail.querySelector<HTMLElement>(`[data-field="${sel}"]`);
        if (el) el.textContent = text;
      };
      setText('name', p.name);
      setText('tagline', p.tagline);
      setText('description', p.description);

      // The heading is hidden-by-default via [data-empty="true"]; clear the
      // flag once we've populated it.
      const name = detail.querySelector<HTMLElement>('[data-field="name"]');
      if (name) name.removeAttribute('data-empty');

      const status = detail.querySelector<HTMLElement>('[data-field="status"]');
      if (status) {
        if (p.status) {
          status.textContent = p.status;
          status.setAttribute('data-status', p.status);
          status.style.display = '';
        } else {
          status.style.display = 'none';
        }
      }

      const highlights = detail.querySelector<HTMLElement>('[data-field="highlights"]');
      if (highlights) {
        highlights.innerHTML = '';
        (p.highlights ?? []).forEach((h) => {
          const span = document.createElement('span');
          span.className = 'highlight';
          span.textContent = h;
          highlights.appendChild(span);
        });
      }

      const tech = detail.querySelector<HTMLElement>('[data-field="tech"]');
      if (tech) {
        tech.innerHTML = '';
        p.tech.forEach((t) => {
          const li = document.createElement('li');
          li.textContent = t;
          tech.appendChild(li);
        });
      }

      const links = detail.querySelector<HTMLElement>('[data-field="links"]');
      if (links) {
        links.innerHTML = '';
        if (p.liveUrl) {
          const a = document.createElement('a');
          a.href = p.liveUrl;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'primary';
          a.textContent = tp.liveDemo;
          links.appendChild(a);
        }
        if (p.githubUrl) {
          const a = document.createElement('a');
          a.href = p.githubUrl;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'secondary';
          a.textContent = tp.githubLink;
          links.appendChild(a);
        }
      }
    };

    const openDetail = (project: LocalizedProject) => {
      populateDetail(project);
      lastFocused = document.activeElement as HTMLElement | null;
      detail.setAttribute('data-open', 'true');
      detail.setAttribute('aria-hidden', 'false');
      intro?.classList.add('is-hidden');
      legend?.classList.add('is-hidden');
      detail.addEventListener('keydown', trapTab);
      // Move focus to the close button once the drawer is open so keyboard
      // users can immediately tab through its contents.
      requestAnimationFrame(() => closeBtn.focus());
    };

    const closeDetail = () => {
      detail.setAttribute('data-open', 'false');
      detail.setAttribute('aria-hidden', 'true');
      intro?.classList.remove('is-hidden');
      legend?.classList.remove('is-hidden');
      detail.removeEventListener('keydown', trapTab);
      sceneHandle?.selectById(null);
      // Restore focus to the element that opened the drawer, or fall back
      // to the body so subsequent tabs continue from the start of the page.
      if (lastFocused && document.contains(lastFocused)) {
        lastFocused.focus();
      } else {
        (document.body as HTMLElement).focus();
      }
      lastFocused = null;
    };

    closeBtn.addEventListener('click', closeDetail);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && detail.getAttribute('data-open') === 'true') {
        closeDetail();
      }
    });

    try {
      const { createProjectsScene } = await import('../lib/three/projectsScene');
      sceneHandle = createProjectsScene({
        canvas,
        hoverLabel,
        projects: localizedProjects,
        reducedMotion,
        onSelect: (project) => openDetail(project),
        onDeselect: () => {
          /* triggered by closeDetail */
        },
      });
    } catch (err) {
      console.warn('projects scene failed to init', err);
      if (sceneRoot) sceneRoot.hidden = true;
      if (fallback) fallback.hidden = false;
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start, { once: true });
  } else {
    start();
  }

  window.addEventListener('beforeunload', () => sceneHandle?.dispose());
</script>

---
import '../styles/projects-scene.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectDetail from '../components/projects/ProjectDetail.astro';
import ProjectGrid from '../components/projects/ProjectGrid.astro';
import { connections, projects } from '../data/projects';
import { asLocale, getTranslations } from '../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);

// Build a project-name lookup so the legend can show "HRM → Platform"
// using the brand names rather than the structural ids.
const projectNameById = Object.fromEntries(projects.map((p) => [p.id, p.name]));

const connectionLegendEntries = connections.map((c) => ({
  color: c.color,
  source: projectNameById[c.sourceId] ?? c.sourceId,
  target: projectNameById[c.targetId] ?? c.targetId,
  // Submodule is a structural sharing relation (HRM lives inside Platform);
  // voice / music are unidirectional flows. Render arrows accordingly.
  arrow: c.kind === 'submodule' ? '↔' : '→',
  kindLabel: t.projectsPage.connectionKindLabels[c.kind],
}));
---

<BaseLayout
  title={t.meta.projects.title}
  description={t.meta.projects.description}
  theme="projects"
  ogImage="/og-projects.png"
>
  <!-- Desktop / capable: WebGL solar system. Visible by default; hidden via
       CSS on small viewports / reduced motion so the layout is stable before
       JS runs. The fallback grid is shown via the same CSS rules. -->
  <div class="projects-scene" data-projects-scene>
    <canvas id="projects-canvas" class="projects-scene__canvas" aria-hidden="true"
    ></canvas>

    <header class="projects-scene__intro" data-intro>
      <p class="projects-scene__eyebrow">{t.projectsPage.eyebrow}</p>
      <h1 class="projects-scene__title">{t.projectsPage.title}</h1>
      <p class="projects-scene__lede">
        {t.projectsPage.lede}
      </p>
    </header>

    <div class="projects-scene__legend" data-legend aria-hidden="true">
      <span><code>hover</code> {t.projectsPage.legendHover}</span>
      <span><code>click</code> {t.projectsPage.legendClick}</span>
      <span><code>drag</code> {t.projectsPage.legendDrag}</span>
      <span><code>scroll</code> {t.projectsPage.legendZoom}</span>
    </div>

    <div class="hover-label" id="hover-label" data-visible="false" aria-hidden="true">
    </div>

    <aside
      class="projects-scene__key"
      data-key
      aria-label={t.projectsPage.keyHeading}
    >
      <p class="projects-scene__key-heading">{t.projectsPage.keyHeading}</p>

      <p class="projects-scene__key-section">{t.projectsPage.keyConnectionsLabel}</p>
      <ul class="projects-scene__key-list">
        {
          connectionLegendEntries.map((entry) => (
            <li class="projects-scene__key-row">
              <span
                class="projects-scene__key-line"
                style={`--line-color:${entry.color}`}
                aria-hidden="true"
              />
              <span class="projects-scene__key-text">
                {entry.source} {entry.arrow} {entry.target}
                <span class="projects-scene__key-kind">— {entry.kindLabel}</span>
              </span>
            </li>
          ))
        }
      </ul>

      <p class="projects-scene__key-section">{t.projectsPage.externalApisLabel}</p>
      <ul class="projects-scene__key-list">
        <li class="projects-scene__key-row">
          <svg
            class="projects-scene__key-satellite"
            viewBox="-16 -16 32 32"
            width="28"
            height="28"
            aria-hidden="true"
          >
            <circle cx="0" cy="0" r="5" fill="rgba(196, 212, 255, 0.45)" />
            <circle cx="9" cy="-3" r="1.6" fill="#80c8ff" />
            <circle
              cx="9"
              cy="-3"
              r="3.2"
              stroke="#80c8ff"
              stroke-width="0.5"
              fill="none"
              opacity="0.7"
            />
            <circle
              cx="9"
              cy="-3"
              r="5"
              stroke="#80c8ff"
              stroke-width="0.4"
              fill="none"
              opacity="0.4"
            />
            <circle
              cx="9"
              cy="-3"
              r="6.6"
              stroke="#80c8ff"
              stroke-width="0.3"
              fill="none"
              opacity="0.2"
            />
          </svg>
          <span class="projects-scene__key-text">
            {t.projectsPage.keyExternalDesc}
          </span>
        </li>
      </ul>
    </aside>

    <div class="projects-scene__credits" data-credits aria-hidden="true">
      <span>{t.navCards.footerCopyright}</span>
      <span class="projects-scene__credits-sep">·</span>
      <span>{t.navCards.footerBuiltWith}</span>
    </div>

    <ProjectDetail />
  </div>

  <!-- Mobile / no-JS / reduced-motion fallback -->
  <div class="projects-fallback" data-projects-fallback>
    <ProjectGrid />
  </div>
</BaseLayout>

<script>
  // Runtime re-imports — these run in the browser. Astro frontmatter imports
  // above run at build time and aren't in scope here.
  import { localizeProjects } from '../data/projects';
  import { asLocale, getTranslations } from '../i18n';
  import { initProjectDrawer } from '../lib/projects/drawer';
  import { scheduleProjectsSceneBoot } from '../lib/projects/boot';

  // Read locale from <html lang> set by BaseLayout, then merge structural
  // project data with the localized text from the i18n dictionaries.
  const locale = asLocale(document.documentElement.lang);
  const t = getTranslations(locale);
  const localizedProjects = localizeProjects(t);
  const tp = t.projectsPage;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isSmall = window.matchMedia('(max-width: 860px)').matches;

  let sceneHandle: {
    selectById: (id: string | null) => void;
    dispose: () => void;
  } | null = null;

  const sceneRoot = document.querySelector<HTMLElement>('[data-projects-scene]');
  const fallback = document.querySelector<HTMLElement>('[data-projects-fallback]');

  const bootProjectsScene = async () => {
    if (reducedMotion || isSmall || !sceneRoot) {
      // CSS @media rules already hide the scene and show the fallback grid
      // for these clients before JS runs. Set the explicit data flag too so
      // the fallback path is observable from CSS / future code, not just an
      // implicit consequence of the WebGL canvas being hidden.
      sceneRoot?.setAttribute('data-fallback-active', 'true');
      fallback?.setAttribute('data-active', 'true');
      return;
    }

    const canvas = document.getElementById('projects-canvas') as HTMLCanvasElement | null;
    const hoverLabel = document.getElementById('hover-label');
    const detail = document.getElementById('project-detail');
    const closeBtn = document.getElementById(
      'project-detail-close',
    ) as HTMLButtonElement | null;
    const intro = document.querySelector<HTMLElement>('[data-intro]');
    const legend = document.querySelector<HTMLElement>('[data-legend]');
    const credits = document.querySelector<HTMLElement>('[data-credits]');
    const key = document.querySelector<HTMLElement>('[data-key]');

    if (!canvas || !hoverLabel || !detail || !closeBtn) return;

    const drawer = initProjectDrawer({
      detail,
      closeBtn,
      intro,
      legend,
      credits,
      key,
      labels: { liveDemo: tp.liveDemo, githubLink: tp.githubLink },
      onClose: () => sceneHandle?.selectById(null),
    });

    try {
      const { createProjectsScene } = await import('../lib/three/projectsScene');
      sceneHandle = createProjectsScene({
        canvas,
        hoverLabel,
        projects: localizedProjects,
        reducedMotion,
        onSelect: (project) => drawer.open(project),
        onDeselect: () => {
          /* triggered by drawer.close via onClose */
        },
      });
    } catch (err) {
      console.warn('projects scene failed to init', err);
      sceneRoot.setAttribute('data-fallback-active', 'true');
      fallback?.setAttribute('data-active', 'true');
      drawer.dispose();
    }
  };

  const bootHandle = scheduleProjectsSceneBoot({ onBoot: bootProjectsScene });

  window.addEventListener('beforeunload', () => {
    bootHandle.cancel();
    sceneHandle?.dispose();
  });
</script>

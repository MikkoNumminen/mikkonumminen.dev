---
import BaseLayout from '../layouts/BaseLayout.astro';
import MountainScene from '../components/experience/MountainScene.astro';
import Goat from '../components/experience/Goat.astro';
import TimelineContent from '../components/experience/TimelineContent.astro';
import { asLocale, getTranslations } from '../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
---

<BaseLayout
  title={t.meta.experience.title}
  description={t.meta.experience.description}
  theme="experience"
  ogImage="/og-experience.png"
>
  <!-- Fixed background scene (mountain layers + sun + stars) -->
  <MountainScene />

  <!-- Goat overlay — absolute viewport coords driven by JS lerping toward
       whichever timeline card is currently closest to viewport center. -->
  <Goat />

  <!-- The scrollable track. Total height drives the parallax progress 0..1. -->
  <div class="experience-track" data-experience-track>
    <TimelineContent />
  </div>
</BaseLayout>

<script>
  import { initExperienceTimeline } from '../lib/gsap/experienceTimeline';

  let handle: { dispose: () => void } | null = null;

  const bootExperienceTimeline = () => {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    handle = initExperienceTimeline({ reducedMotion });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootExperienceTimeline, { once: true });
  } else {
    bootExperienceTimeline();
  }

  window.addEventListener('beforeunload', () => handle?.dispose());
</script>

<style is:global>
  /* The base layout body background would peek through during scroll on
     this page since the mountain scene is fixed. Override it. */
  html[data-theme='experience'],
  body[data-theme='experience'] {
    background: #0e0820;
  }

  .experience-track {
    position: relative;
    z-index: 1;
  }
</style>

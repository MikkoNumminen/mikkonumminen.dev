---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/contact/Terminal.astro';
import MobileContactCard from '../components/contact/MobileContactCard.astro';
import { asLocale, getTranslations } from '../i18n';

const locale = asLocale(Astro.currentLocale);
const t = getTranslations(locale);
---

<BaseLayout
  title={t.meta.contact.title}
  description={t.meta.contact.description}
  theme="contact"
  ogImage="/og-contact.png"
>
  <Terminal />
  <MobileContactCard />
</BaseLayout>

<script>
  import { initTerminal } from '../lib/terminal/terminal';

  const bootContactPage = () => initTerminal(document);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootContactPage, { once: true });
  } else {
    bootContactPage();
  }
</script>

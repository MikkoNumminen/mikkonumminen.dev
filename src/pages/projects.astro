---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectDetail from '../components/projects/ProjectDetail.astro';
import ProjectGrid from '../components/projects/ProjectGrid.astro';
---

<BaseLayout
  title="Projects — Mikko Numminen"
  description="Interactive solar system of selected projects by Mikko Numminen."
  theme="projects"
  ogImage="/og-projects.svg"
>
  <!-- Desktop / capable: WebGL solar system -->
  <div class="projects-scene" data-projects-scene>
    <canvas
      id="projects-canvas"
      class="projects-scene__canvas"
      aria-hidden="true"></canvas>

    <header class="projects-scene__intro" data-intro>
      <p class="projects-scene__eyebrow">Selected work</p>
      <h1 class="projects-scene__title">Projects</h1>
      <p class="projects-scene__lede">
        A small solar system of things I have built. Hover a planet for the
        elevator pitch, click to zoom in.
      </p>
    </header>

    <div class="projects-scene__legend" data-legend aria-hidden="true">
      <span><kbd>hover</kbd> to inspect</span>
      <span><kbd>click</kbd> a planet to focus</span>
    </div>

    <div
      class="hover-label"
      id="hover-label"
      data-visible="false"
      aria-hidden="true">
    </div>

    <ProjectDetail />
  </div>

  <!-- Mobile / no-JS / reduced-motion fallback -->
  <noscript>
    <ProjectGrid />
  </noscript>

  <div class="projects-fallback" data-projects-fallback hidden>
    <ProjectGrid />
  </div>
</BaseLayout>

<script>
  import type { Project } from '../data/projects';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isSmall = window.matchMedia('(max-width: 860px)').matches;

  let sceneHandle: { selectById: (id: string | null) => void; dispose: () => void } | null = null;

  const sceneRoot = document.querySelector<HTMLElement>('[data-projects-scene]');
  const fallback = document.querySelector<HTMLElement>('[data-projects-fallback]');

  const start = async () => {
    if (reducedMotion || isSmall || !sceneRoot) {
      // Show fallback grid
      if (sceneRoot) sceneRoot.hidden = true;
      if (fallback) fallback.hidden = false;
      return;
    }

    const canvas = document.getElementById('projects-canvas') as HTMLCanvasElement | null;
    const hoverLabel = document.getElementById('hover-label');
    const detail = document.getElementById('project-detail');
    const closeBtn = document.getElementById('project-detail-close');
    const intro = document.querySelector<HTMLElement>('[data-intro]');
    const legend = document.querySelector<HTMLElement>('[data-legend]');

    if (!canvas || !hoverLabel || !detail || !closeBtn) return;

    const populateDetail = (p: Project) => {
      const setText = (sel: string, text: string) => {
        const el = detail.querySelector<HTMLElement>(`[data-field="${sel}"]`);
        if (el) el.textContent = text;
      };
      setText('name', p.name);
      setText('tagline', p.tagline);
      setText('description', p.description);

      const status = detail.querySelector<HTMLElement>('[data-field="status"]');
      if (status) {
        if (p.status) {
          status.textContent = p.status;
          status.setAttribute('data-status', p.status);
          status.style.display = '';
        } else {
          status.style.display = 'none';
        }
      }

      const highlights = detail.querySelector<HTMLElement>('[data-field="highlights"]');
      if (highlights) {
        highlights.innerHTML = '';
        (p.highlights ?? []).forEach((h) => {
          const span = document.createElement('span');
          span.className = 'highlight';
          span.textContent = h;
          highlights.appendChild(span);
        });
      }

      const tech = detail.querySelector<HTMLElement>('[data-field="tech"]');
      if (tech) {
        tech.innerHTML = '';
        p.tech.forEach((t) => {
          const li = document.createElement('li');
          li.textContent = t;
          tech.appendChild(li);
        });
      }

      const links = detail.querySelector<HTMLElement>('[data-field="links"]');
      if (links) {
        links.innerHTML = '';
        if (p.liveUrl) {
          const a = document.createElement('a');
          a.href = p.liveUrl;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'primary';
          a.textContent = 'live demo →';
          links.appendChild(a);
        }
        if (p.githubUrl) {
          const a = document.createElement('a');
          a.href = p.githubUrl;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'secondary';
          a.textContent = 'github';
          links.appendChild(a);
        }
      }
    };

    const openDetail = (project: Project) => {
      populateDetail(project);
      detail.setAttribute('data-open', 'true');
      detail.setAttribute('aria-hidden', 'false');
      intro?.classList.add('is-hidden');
      legend?.classList.add('is-hidden');
    };

    const closeDetail = () => {
      detail.setAttribute('data-open', 'false');
      detail.setAttribute('aria-hidden', 'true');
      intro?.classList.remove('is-hidden');
      legend?.classList.remove('is-hidden');
      sceneHandle?.selectById(null);
    };

    closeBtn.addEventListener('click', closeDetail);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDetail();
    });

    try {
      const { createProjectsScene } = await import('../lib/three/projectsScene');
      sceneHandle = createProjectsScene({
        canvas,
        hoverLabel,
        reducedMotion,
        onSelect: (project) => openDetail(project),
        onDeselect: () => {
          /* triggered by closeDetail */
        },
      });
    } catch (err) {
      console.warn('projects scene failed to init', err);
      if (sceneRoot) sceneRoot.hidden = true;
      if (fallback) fallback.hidden = false;
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start, { once: true });
  } else {
    start();
  }

  window.addEventListener('beforeunload', () => sceneHandle?.dispose());
</script>

<style is:global>
  .projects-scene {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse at center, #050818 0%, #02040c 60%, #010206 100%);
  }

  .projects-scene__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .projects-scene__intro {
    position: absolute;
    top: 7.5rem;
    left: 3rem;
    max-width: 380px;
    z-index: 10;
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .projects-scene__intro.is-hidden {
    opacity: 0;
    transform: translateY(-12px);
  }

  .projects-scene__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(196, 212, 255, 0.5);
    margin: 0 0 1rem;
  }

  .projects-scene__title {
    font-size: clamp(2.5rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 1rem;
  }

  .projects-scene__lede {
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(230, 236, 255, 0.65);
    margin: 0;
  }

  .projects-scene__legend {
    position: absolute;
    bottom: 2.5rem;
    left: 3rem;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(196, 212, 255, 0.45);
    transition: opacity 0.45s ease;
  }

  .projects-scene__legend.is-hidden {
    opacity: 0;
  }

  .projects-scene__legend kbd {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border: 1px solid rgba(120, 170, 255, 0.3);
    border-radius: 4px;
    color: #c4d4ff;
    margin-right: 0.35rem;
    background: rgba(120, 170, 255, 0.05);
  }

  .hover-label {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 30;
    pointer-events: none;
    padding: 0.85rem 1.1rem;
    background: rgba(8, 14, 32, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(120, 170, 255, 0.4);
    border-radius: 10px;
    color: #e6ecff;
    box-shadow: 0 0 24px rgba(80, 130, 255, 0.18);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 180px;
    opacity: 0;
    transform: translate(-9999px, -9999px) translateY(8px);
    transition: opacity 0.2s ease;
    will-change: transform, opacity;
  }

  .hover-label[data-visible='true'] {
    opacity: 1;
  }

  .hover-label__name {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .hover-label__tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(196, 212, 255, 0.7);
  }

  .hover-label__tech {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(196, 212, 255, 0.45);
    letter-spacing: 0.05em;
  }

  @media (max-width: 860px) {
    .projects-scene__intro {
      left: 1.5rem;
      right: 1.5rem;
      top: 6.5rem;
      max-width: none;
    }
    .projects-scene__legend {
      left: 1.5rem;
      bottom: 1.5rem;
    }
  }
</style>

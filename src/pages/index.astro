---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mikko Numminen — full-stack developer"
  description="Portfolio of Mikko Numminen, a full-stack developer from Finland building production web applications."
  theme="home"
>
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm uppercase tracking-[0.3em] text-white/50">coming soon</p>
      <h1 class="mt-4 text-5xl sm:text-7xl font-semibold tracking-tight">
        Mikko Numminen
      </h1>
      <p class="mt-6 text-white/60 max-w-md mx-auto">
        full-stack developer · Finland
      </p>
    </div>
  </section>
</BaseLayout>
